# ══════════════════════════════════════════════════════
# Bilim Platform — Орта айнымалылары шаблоны
# Нақты мәндерді .env.local файлына көшіріп, толтырыңыз
# .env.local файлы GitHub-қа жүктелмейді (gitignore-да)
# ══════════════════════════════════════════════════════

# ── Supabase (supabase.com дан алыңыз) ──────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Mux Video (mux.com дан алыңыз) ──────────────────
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret
NEXT_PUBLIC_MUX_ENV_KEY=your-mux-env-key

# ── Stripe (stripe.com дан алыңыз) ──────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Kaspi Pay (Kaspi бизнес порталынан) ─────────────
KASPI_MERCHANT_ID=your-kaspi-merchant-id
KASPI_API_KEY=your-kaspi-api-key

# ── Жалпы ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PLATFORM_COMMISSION=0.20
